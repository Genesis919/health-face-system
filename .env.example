# Supabase 專案網址
# 請到 Supabase 後台 Settings > API > Project URL 複製
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 前端公開金鑰
# 請到 Supabase 後台 Settings > API > Project API keys > anon public 複製
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 伺服器端 service role 金鑰
# 請到 Supabase 後台 Settings > API > Project API keys > service_role secret 複製
# 這個值只能放在 .env.local，不要提交到版本控制
SUPABASE_SERVICE_ROLE_KEY=

# 機構名稱
# 會顯示在登入首頁、側欄品牌與健康臉譜 PNG 匯出畫面
# 若未填寫，系統預設為：創世基金會斗六院
NEXT_PUBLIC_INSTITUTION_NAME=創世基金會斗六院
